<header class="site-header">

    <div class="container header-row">
        <div class="brand">
            <a href="/" class="brand-link">Book Notes</a>
            <p class="tagline">Short notes + ratings, so you can remember good ideas.</p>
        </div>
        
        <nav class="nav">
            <% if (currentUser) { %>
                <a class="nav-link <%= sort === 'recent' ? 'active' : '' %>" href="/?sort=recent">Recent</a>
                <a class="nav-link <%= sort === 'rating' ? 'active' : '' %>" href="/?sort=rating">Rating</a>
                <a class="nav-link <%= sort === 'title' ? 'active' : '' %>" href="/?sort=title">Title</a>
                <a class="nav-link primary" href="/new">+ Add book</a>
                <form action="/logout" method="POST">
                    <button class="btn ghost" type="submit">Logout</button>
                </form>
            <% } else { %>
                <a class="nav-link <%= page === 'login' ? 'active' : '' %>" href="/login">Login</a>
                <a class="nav-link primary <%= page === 'register' ? 'active' : '' %>" href="/register">Create account</a>
            <% } %>
        </nav>
    </div>
            

</header>

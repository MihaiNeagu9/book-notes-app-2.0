<%
  const currentSort = "recent";
  const bookList = [];
%>

<%- include("partials/head", { title: "" }) %>
<%- include("partials/header", { currentUser: true, sort: currentSort }) %>

<main class="container page">
  <section class="page-top">
    <h1 class="page-title">My Books</h1>
    <p class="page-subtitle">Sorting: <strong><%= currentSort %></strong></p>
  </section>

  <% if (bookList.length === 0) { %>
    <section class="empty-state">
      <p class="muted">No books yet. Add your first book to start collecting notes.</p>
    </section>
  <% } else { %>
    <section class="grid">
      <% bookList.forEach((book) => { %>
        <article class="card">
          <div class="card-cover">
            <img
              src="<%= book.cover_id ? `https://covers.openlibrary.org/b/id/${book.cover_id}-M.jpg` : '/images/image.png' %>"
              alt="<%= book.title || 'Book cover' %>"
            >
          </div>

          <div class="card-body">
            <h2 class="card-title"><%= book.title || "Untitled" %></h2>
            <p class="muted"><%= book.author || "Unknown author" %></p>

            <div class="meta">
              <span class="pill">&#9733; <%= book.rating ?? "-" %> / 10</span>
            </div>

            <p class="notes"><%= book.notes || "No notes yet." %></p>

            <div class="actions">
              <a class="btn ghost" href="/edit/<%= book.id %>">Edit</a>
              <form action="/delete/<%= book.id %>" method="POST">
                <button class="btn danger" type="submit" onclick="return confirm('Are you sure you want to delete this book?')">Delete</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  <% } %>
</main>

<%- include("partials/footer") %>
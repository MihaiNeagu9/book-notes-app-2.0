<%- include("partials/head", { title: "Login" }) %>
<%- include("partials/header", { page: "login", currentUser: null, sort: "recent" }) %>

<main class="container page narrow">
  <h1 class="page-title login-register-title">Login</h1>

  <% if (error) { %>
    <section class="empty-state">
      <p class="muted"><%= error %></p>
    </section>
  <% } %>

  <form class="form" action="/login" method="POST">
    <div class="field">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required value="<%= form?.email ?? '' %>">
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required>
    </div>

    <div class="form-actions">
      <a class="btn ghost" href="/register">Create account</a>
      <button class="btn" type="submit">Login</button>
    </div>
  </form>
</main>

<%- include("partials/footer") %>

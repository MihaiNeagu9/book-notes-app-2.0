<%- include("partials/head", { title: "Add book" }) %>
<%- include("partials/header", { sort, page: "books", currentUser }) %>

<main class="container page narrow">
  <h1 class="page-title">Add a book</h1>

  <% if (error) { %>
    <section class="empty-state">
      <p class="muted"><%= error %></p>
    </section>
  <% } %>

  <form class="form" action="/add" method="POST">
    <div class="field">
      <label for="title">Title *</label>
      <input id="title" name="title" required value="<%= form?.title ?? '' %>">
    </div>

    <div class="field">
      <label for="author">Author</label>
      <input id="author" name="author" value="<%= form?.author ?? '' %>">
    </div>

    <div class="field">
      <label for="rating">Rating (1-10)</label>
      <input id="rating" name="rating" type="number" min="1" max="10" value="<%= form?.rating ?? '' %>">
    </div>

    <div class="field">
      <label for="cover_id">OpenLibrary Cover ID</label>
      <input id="cover_id" name="cover_id" value="<%= form?.cover_id ?? '' %>">
    </div>

    <div class="field">
      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="6" placeholder="The key points, briefly..."><%= form?.notes ?? '' %></textarea>
    </div>

    <div class="form-actions">
      <a class="btn ghost" href="/">Cancel</a>
      <button class="btn" type="submit">Save</button>
    </div>
  </form>
</main>

<%- include("partials/footer") %>

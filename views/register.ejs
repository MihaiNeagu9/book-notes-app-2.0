<%- include("partials/head", { title: "Register" }) %>
<%- include("partials/header", { page: "register", currentUser: null, sort: "recent" }) %>

<main class="container page narrow">
  <h1 class="page-title">Create account</h1>

  <% if (error) { %>
    <section class="empty-state">
      <p class="muted"><%= error %></p>
    </section>
  <% } %>

  <form class="form" action="/register" method="POST">
    <div class="field">
      <label for="name">Name</label>
      <input id="name" name="name" required value="<%= form?.name ?? '' %>">
    </div>

    <div class="field">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required value="<%= form?.email ?? '' %>">
    </div>

    <div class="field">
      <label for="password">Password (min 6 chars)</label>
      <input id="password" name="password" type="password" minlength="6" required>
    </div>

    <div class="form-actions">
      <a class="btn ghost" href="/login">Already have account</a>
      <button class="btn" type="submit">Register</button>
    </div>
  </form>
</main>

<%- include("partials/footer") %>
